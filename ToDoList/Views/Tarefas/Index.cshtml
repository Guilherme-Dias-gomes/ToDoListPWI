@using ToDoList.Models

@model IEnumerable<TarefasModel>

@{
    ViewData["Title"] = "Minhas Tarefas";
}

<div>
    <h1>Minhas Tarefas</h1>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nome</th>
                <th>Descricao</th>
                <th>Prazo</th>
                <th>Prioridade</th>
                <th>Status</th>
                <th>Opções</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tarefa in Model)
            {
                <tr>
                    <td>@tarefa.Id</td>
                    <td>@tarefa.Nome</td>
                    <td>@tarefa.Descricao</td>
                    <td>@tarefa.Prazo.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@tarefa.Prioridade</td>
                    <td>
                        @if (tarefa.Status == true)
                        {
                        <span class="badge bg-success">Concluída</span>
                        }
                        else
                        {
                        <span class="badge bg-warning text-dark">Pendente</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@tarefa.Id" class="btn btn-sm btn-primary">Editar</a>
                        <button type="button"
                                class="btn btn-sm btn-danger btn-deletar"
                                data-bs-toggle="modal"
                                data-bs-target="#modalExcluir"
                                data-id="@tarefa.Id"
                                data-nome="@tarefa.Nome">
                            Excluir
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal de Confirmação -->
<div class="modal fade" id="modalExcluir" tabindex="-1" aria-labelledby="modalExcluirLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalExcluirLabel">Confirmar Exclusão</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Tem certeza que deseja excluir a tarefa <strong id="nomeTarefaModal"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn border-secondary" data-bs-dismiss="modal">Cancelar</button>

                <!-- Formulário que enviará a requisição de exclusão para o Controller -->
                <form asp-action="Delete" method="post" id="formExcluir">
                    <input type="hidden" name="id" id="idTarefaModal" />
                    <button type="submit" class="btn btn-danger">Excluir definitivamente</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modalExcluir = document.getElementById('modalExcluir');

            modalExcluir.addEventListener('show.bs.modal', function (event) {
                // Botão que disparou o modal
                var botao = event.relatedTarget;

                // Extrai as informações dos atributos data-*
                var idTarefa = botao.getAttribute('data-id');
                var nomeTarefa = botao.getAttribute('data-nome');

                // Atualiza os campos internos do modal
                var modalNome = modalExcluir.querySelector('#nomeTarefaModal');
                var modalInputId = modalExcluir.querySelector('#idTarefaModal');

                modalNome.textContent = nomeTarefa;
                modalInputId.value = idTarefa;
            });
        });
    </script>
}
